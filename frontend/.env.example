# Ditto frontend configuration. Copy to `.env.local` and adjust.

# Where the Ditto backend lives. The intelligence map (Server Component) calls
# this directly; the cluster drawer (browser) calls it through the same-origin
# proxy at app/api/ditto/[...path], so CORS never has to be configured.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Data source. Unset (or anything other than "mock") = hit the live API above.
# Set to "mock" to render entirely from typed fixtures with no backend running
# — the demo safety net. A visible "Fixtures" badge appears whenever this is on.
# NEXT_PUBLIC_DITTO_SOURCE=mock

# ---------------------------------------------------------------------------
# Restricted mode — the hosted demo's credit guardrail.
#
# When on: a banner explains the cap, and repo maps note that the analysis is
# cached and re-analysis is disabled. Leave it OFF locally (no cap applies).
#
# ⚠️ NEXT_PUBLIC_* values are INLINED at build time, so changing one on Vercel
# does nothing until you REDEPLOY. Every surface that reads these flags is
# server-rendered, so the non-prefixed names below are checked FIRST and are
# read per request — set those to toggle without rebuilding.
# ---------------------------------------------------------------------------

# Runtime (preferred — no redeploy needed):
# RESTRICTED_MODE=true
# LIVE_MAX_FUNCTIONS=300

# Build-time equivalents (require a redeploy to take effect):
# NEXT_PUBLIC_RESTRICTED_MODE=true
# NEXT_PUBLIC_LIVE_MAX_FUNCTIONS=300
