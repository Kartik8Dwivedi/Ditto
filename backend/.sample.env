# Server
NODE_ENV=development
PORT=3001

# Database (required)
MONGO_URI=mongodb://127.0.0.1:27017/microservice

# CORS — comma-separated origins, or "*" to allow all
CORS_ORIGIN=*

# OpenAI (required)
OPENAI_API_KEY=sk-...

# Model ids — verify against https://developers.openai.com/api/docs/models
# before a run. A "model not found" 404 is fixed HERE, not in service code.
# Cheap tier runs once per function (fingerprints); flagship only ever sees
# candidate clusters (adjudication). Both verified 2026-07-17.
#   gpt-5.4-nano   $0.20 / $1.25 per 1M in/out
#   gpt-5.6-terra  $2.50 / $15   per 1M in/out
OPENAI_MODEL_CHEAP=gpt-5.4-nano
OPENAI_MODEL_FLAGSHIP=gpt-5.6-terra
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=60000

# Optional — raises GitHub's rate limit for the local indexer.
GITHUB_TOKEN=

# On-demand analysis (docs/ONDEMAND.md). All OPTIONAL: leave unset locally and
# POST /api/v1/analyze runs the job inline. Set all five in the Cloud Run
# service and the job is enqueued to Cloud Tasks and pushed to /internal/run.
#   TASK_SECRET guards /internal/run — unset means that route rejects every call.
GCP_PROJECT=
TASKS_LOCATION=asia-south2
TASKS_QUEUE=ditto-jobs
SERVICE_URL=https://ditto-backend-xxxxxxxxxxxx.asia-south2.run.app
TASK_SECRET=

# LIVE CAPS — the ONLY knobs between a rich demo run and a cheap one.
# Switching mode is an env edit + redeploy. No code change, ~10 seconds.
#
#   TEST MODE (our hero runs — a full analysis like the offline cline run)
#     LIVE_MAX_FUNCTIONS=2000
#     LIVE_CANDIDATE_CAP=100
#
#   JUDGING MODE (flip to this BEFORE judging — protects the API budget when
#   strangers are pasting URLs; ~₹25-35 per run instead of several hundred)
#     LIVE_MAX_FUNCTIONS=600
#     LIVE_CANDIDATE_CAP=20
#
# A repo with MORE than LIVE_MAX_FUNCTIONS is refused outright rather than
# silently truncated, so a completed live run always has analyzed == total.
# The active values are printed at startup and at the start of every job.
# These bound the LIVE path only; the offline CLI pipeline is unaffected.
LIVE_MAX_FUNCTIONS=2000
LIVE_CANDIDATE_CAP=100

# Wall-clock budget for one live run (ms), checked at each stage boundary.
# Cloud Run kills the request at 1200s; aborting ourselves at 1080s turns a
# silent hang (job stuck on "running") into an honest failed job.
LIVE_DEADLINE_MS=1080000
